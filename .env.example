# Vorlage für Umgebungsvariablen. Kopieren nach .env (steht in .gitignore).
# NIEMALS echte Werte hier eintragen.
#
# elwasys konfiguriert die Anwendungen primär über andere Wege:
#   - Backend:  backend/src/main/resources/application.yml (per Spring-Env/Profile
#               überschreibbar, z. B. SPRING_DATASOURCE_*).
#   - Terminal: elwasys.properties (siehe Client-Raspi, defaultconfig.properties).
#   - Deployment: deploy/compose/.env.example (Compose-spezifische Variablen).
# Diese Datei dient nur als zentraler Platzhalter/Startpunkt.

# --- Backend (Beispiele; Spring liest die entsprechenden Properties) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/elwasys
# SPRING_DATASOURCE_USERNAME=elwaportal
# SPRING_DATASOURCE_PASSWORD=
# ELWASYS_NOTIFICATIONS_ENABLED=false
