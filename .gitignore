# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

.DS_Store
target/

# IDE / editor config (not part of the build; keep out of the repo)
.idea/
*.iml
.settings/
.classpath
.project
# .vscode/ is intentionally checked in (shared recommendations); ignore only local leftovers:
.vscode/*.local

elwasys.properties

.client-uid

# Transient agent worktrees (Claude Code parallel-agent isolation)
.claude/worktrees/

# Secrets / local config
.env
.env.*
!.env.example
.claude/settings.local.json

# Vaadin Flow (Phase 3 AP1, backend module, see docs/kb/05-migration-plan.md): auto-regenerated
# frontend tooling output (from "vaadin:prepare-frontend"/"vaadin:build-frontend", bound to
# the Maven build, see backend/pom.xml) - never hand-edited, always safe to delete/regenerate.
backend/src/main/frontend/generated/
backend/node_modules/
backend/package.json
backend/package-lock.json
backend/pnpm-lock.yaml
backend/types.d.ts
backend/vite.generated.ts
backend/tsconfig.json

# Terminal readiness marker (Phase 6 AP5): runtime artifact written by
# TerminalReadinessMarker when the client reaches SELECT_DEVICE. On a device it
# lives in /opt/elwasys/; in dev/test runs it lands in the working directory.
.terminal-ready
