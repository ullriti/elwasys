root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false

# Maven POMs and other XML in this repo are tab-indented.
[*.xml]
indent_style = tab

[*.{yml,yaml,json,ts,tsx,js,jsx,css,html}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab
