# elwasys backend – Compose-Umgebungsvariablen (Phase 2 AP6, siehe kb/05-migration-plan.md
# und kb/04-build-and-run.md, Abschnitt "Deployment").
#
# Kopieren nach ".env" im selben Verzeichnis und Platzhalter durch echte Werte ersetzen:
#   cp .env.example .env
# ".env" ist NICHT eingecheckt (siehe .gitignore) - hier stehen bewusst nur Platzhalter,
# KEINE echten Secrets.

# --- PostgreSQL (mitgelieferter Container, siehe docker-compose.yml) -----------------------
# Wird nur für die Variante "eigene Postgres-Instanz für Neuinstallationen" benutzt (Standard-
# Profil in docker-compose.yml). Bei einer leeren Datenbank legt Flyway (im Backend) beim
# ersten Start das komplette Bestandsschema per Baseline-Migration an - es gibt bewusst KEIN
# gemountetes database-init.sql mehr (das wäre für die "Neuinstallation"-Variante doppelte
# Schemaverwaltung neben Flyway). Für die Variante "Anbindung an eine Bestands-DB" wird dieser
# Container gar nicht gestartet, siehe README-Hinweis im Kompose-File unten.
POSTGRES_DB=elwasys
POSTGRES_USER=elwasys
POSTGRES_PASSWORD=changeme-strong-password

# --- Backend: Datenbankverbindung ------------------------------------------------------------
# Standard (mitgelieferter Postgres-Service "postgres" aus docker-compose.yml): unverändert
# lassen, die Compose-Datei setzt ELWASYS_DB_URL/_USER/_PASSWORD bereits passend zum
# postgres-Service oben. Für die Variante "Bestands-DB" stattdessen hier überschreiben, z.B.:
#   ELWASYS_DB_URL=jdbc:postgresql://bestehende-db.example.internal:5432/elwasys
#   ELWASYS_DB_USER=elwaportal
#   ELWASYS_DB_PASSWORD=<Passwort der Bestands-DB>
# und den "postgres"-Service in docker-compose.yml nicht mitstarten (z.B.
# "docker compose up backend" statt "docker compose up", oder den Service auskommentieren).

# --- Backend: Benachrichtigungsdienst (optional, Default AUS - siehe AP5) --------------------
ELWASYS_NOTIFICATIONS_ENABLED=false
ELWASYS_SMTP_HOST=
ELWASYS_SMTP_PORT=465
ELWASYS_SMTP_USER=
ELWASYS_SMTP_PASSWORD=
ELWASYS_SMTP_SENDER_ADDRESS=
ELWASYS_SMTP_AUTH=true
ELWASYS_SMTP_USE_SSL=true
ELWASYS_PUSHOVER_API_TOKEN=

# --- Backend: Auth (siehe AP3 - Default AUS; ob/wann aktiviert wird, ist eine Entscheidung
# der Produktivumschaltung Phase 6, siehe kb/05-migration-plan.md "Entscheidungen") ----------
ELWASYS_AUTH_REHASH_ON_LOGIN=false

# --- Reverse-Proxy/TLS-Profil (siehe docker-compose.proxy.yml) -------------------------------
# Nur relevant, wenn das optionale TLS-Overlay verwendet wird (Caddy als Reverse Proxy,
# automatisches Let's-Encrypt-TLS). Öffentlicher DNS-Name, unter dem das Backend erreichbar
# sein soll; muss auf diesen Host zeigen, damit Caddy ein Zertifikat ausstellen kann.
ELWASYS_PUBLIC_HOSTNAME=elwasys.example.com
# Für lokale Tests ohne echten DNS-Namen/öffentliche Erreichbarkeit: siehe Kommentar in
# docker-compose.proxy.yml (interne/selbstsignierte statt automatischer Let's-Encrypt-TLS).
