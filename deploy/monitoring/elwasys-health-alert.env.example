# Konfiguration für elwasys-health-alert.sh (Issue #83/H4). Nach elwasys-health-alert.env
# kopieren und Werte eintragen; der systemd-Timer/Cron liest diese Datei als EnvironmentFile.
# Enthält Zugangsdaten (Pushover-Token) -> NICHT einchecken, Rechte 600.

# --- Betriebs-Health-Endpoint ----------------------------------------------------------------
# Die dedizierte Alerting-Gruppe (nur die betrieblichen Indicators). Auf demselben Host wie das
# Backend i.d.R. localhost; das Backend bindet ohnehin nur an 127.0.0.1 (TLS-Pflicht, Issue #35).
ELWASYS_ALERT_HEALTH_URL=http://127.0.0.1:8080/actuator/health/operational
ELWASYS_ALERT_HTTP_TIMEOUT=10

# --- Zertifikats-Ablauf (#89) ----------------------------------------------------------------
# Öffentlicher HTTPS-Endpoint (host oder host:port). Leer lassen, wenn TLS automatisch erneuert
# wird (Caddy/cert-manager) - relevant vor allem für den Selbstverwaltungs-Pfad ohne Auto-
# Erneuerung. Alarm, wenn das Zertifikat in weniger als ELWASYS_ALERT_CERT_MIN_DAYS Tagen abläuft.
ELWASYS_ALERT_TLS_HOST=
ELWASYS_ALERT_CERT_MIN_DAYS=14

# --- Plattenplatz (#89) ----------------------------------------------------------------------
# Leerzeichen-getrennte Pfade (Docker-Datenverzeichnis, Backup-Verzeichnis). Leer = Check aus.
ELWASYS_ALERT_DISK_PATHS=/var/lib/docker /var/backups/elwasys
ELWASYS_ALERT_DISK_MAX_PERCENT=90

# --- Anti-Spam / Zustand ---------------------------------------------------------------------
ELWASYS_ALERT_STATE_DIR=/var/lib/elwasys-health-alert
# Wiederholungs-Erinnerung, solange ein Check fehlerhaft bleibt (Sekunden; 0 = nur auf Wechsel).
ELWASYS_ALERT_RENOTIFY_SECONDS=21600

# --- Zustellkanäle (mindestens EINEN einrichten!) --------------------------------------------
# Pushover: eigener App-Token + User-/Group-Key für BETRIEBS-Alarme (bewusst getrennt vom
# Nutzer-Benachrichtigungs-Token des Backends).
ELWASYS_ALERT_PUSHOVER_TOKEN=
ELWASYS_ALERT_PUSHOVER_USER=
# Mail: Empfänger + Versandkommando (Default 'mail -s'; z.B. msmtp/mailutils vorausgesetzt).
ELWASYS_ALERT_MAIL_TO=
ELWASYS_ALERT_MAIL_CMD=mail -s
